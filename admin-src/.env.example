# 어드민 빌드용 환경변수
#
# 빌드 직전에 admin-src/scripts/check-env.cjs 가 자동 실행되어
# 아래 값들이 비어 있으면 빌드를 즉시 실패시킵니다.
# (깨진 결과물이 운영에 올라가는 사고 방지)
#
# 로컬 개발자: 이 파일을 .env 로 복사한 뒤 실제 값을 채워 주세요.
# Railway 배포: 같은 이름의 변수를 Service Variables 에 등록하세요.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
